# Copy to .env and fill in values:
#   cp artifacts/api-server/.env.example artifacts/api-server/.env

# ---------------------------------------------------------------------------
# Required — API server
# ---------------------------------------------------------------------------
PORT=3001

# PostgreSQL connection string (local, Docker, or hosted Neon/Supabase)
# Local native:  postgresql://YOUR_USERNAME@localhost:5432/insurewise
# Docker:         postgresql://postgres:postgres@localhost:5432/insurewise
DATABASE_URL=postgresql://YOUR_USERNAME@localhost:5432/insurewise

# ---------------------------------------------------------------------------
# AI (OpenAI-compatible) — required for chat, explain, parse, optimizer
# Recommended: use your own OpenAI key (see commented block below).
# ---------------------------------------------------------------------------

# Default: hackathon Hugging Face endpoint (best-effort; may be unavailable)
OPENAI_API_KEY=test
OPENAI_BASE_URL=https://vjioo4r1vyvcozuj.us-east-2.aws.endpoints.huggingface.cloud/v1
AI_MODEL=openai/gpt-oss-120b

# Recommended — your own OpenAI account:
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini

# Any other OpenAI-compatible provider (Groq, Together, Ollama, etc.) also works:
# OPENAI_API_KEY=your-provider-key
# OPENAI_BASE_URL=https://your-provider/v1
# AI_MODEL=your-model-id

# ---------------------------------------------------------------------------
# Optional — Moorcheh "Ask Expert" RAG only (free tier at console.moorcheh.ai)
# ---------------------------------------------------------------------------
MOORCHEH_API_KEY=
